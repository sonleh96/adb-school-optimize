DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@<host>:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# GCS is only needed once raster reading/clipping is implemented.
GCS_BUCKET=<bucket-name>

# For local development, prefer one of:
# 1. GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# 2. Application Default Credentials via gcloud
# In Cloud Run, prefer workload identity instead of a JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GCS_PROJECT=<gcp-project-id>

# Either define per-layer raster locations:
GCS_FLOOD_RASTER_PATH=rise-png/rasters/flood/PNG_flood_JRC.tif
GCS_LANDCOVER_RASTER_PATH=rise-png/rasters/landcover/Dynamic World LULC.tif
GCS_FLOOD_RASTER_CRS=EPSG:4326
GCS_LANDCOVER_RASTER_CRS=EPSG:4326

# Or define a shared prefix and let the API resolve <prefix>/<layer>.
# GCS_RASTER_PREFIX=rise-png/rasters
